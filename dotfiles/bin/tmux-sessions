#!/bin/bash

current=$(tmux display-message -p '#S')
output=""

while IFS=$'\t' read -r session_id session_name; do
  if [ "$session_name" = "$current" ]; then
    output+="#[range=session|${session_id}]#[fg=#88c0d0 bold] ${session_name} #[default nobold]#[norange]"
  else
    output+="#[range=session|${session_id}]#[fg=#7b88a0] ${session_name} #[default]#[norange]"
  fi
done < <(tmux list-sessions -F $'#{session_id}\t#{session_name}')

printf '%s' "$output"
