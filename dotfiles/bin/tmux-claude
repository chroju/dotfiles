#!/bin/bash
# List tmux windows with Claude Code status and switch with fzf

list_entries() {
  local current_session current_window
  current_session=$(tmux display-message -p '#{session_name}')
  current_window=$(tmux display-message -p '#{window_index}')

  local claude_window_list
  claude_window_list=$(tmux list-panes -a -F $'#{session_name}\t#{window_index}\t#{pane_current_command}' \
    | awk -F'\t' '$3 == "node" || $3 == "claude" {print $1 ":" $2}' | sort -u)

  while IFS=$'\t' read -r sess win_index win_name claude_done claude_working bell_flag; do
    local status current icon
    if echo "$claude_window_list" | grep -qxF "${sess}:${win_index}"; then
      if [ "$claude_working" = "1" ]; then
        status="\033[5;36m>> working\033[0m"
      elif [ "$bell_flag" = "1" ]; then
        status="\033[5;33m!! waiting\033[0m"
      elif [ "$claude_done" = "1" ]; then
        status="\033[32mvv done   \033[0m"
      else
        status="\033[37m.. idle   \033[0m"
      fi
      icon="\033[38;5;208m✳ \033[0m"
    else
      status="\033[90m-- -      \033[0m"
      icon="  "
    fi

    if [ "$sess" = "$current_session" ] && [ "$win_index" = "$current_window" ]; then
      current="\033[35m*\033[0m "
    else
      current="  "
    fi

    printf '%b\t%b\t%b\n' "${sess}" "${win_index}" "${current}${status}  ${icon}${sess}:${win_index} [${win_name}]"
  done < <(tmux list-windows -a -F $'#{session_name}\t#{window_index}\t#{window_name}\t#{@claude_done}\t#{@claude_working}\t#{window_bell_flag}')
}

if [ "$1" = "--list" ]; then
  list_entries
  exit 0
fi

[ -z "$TMUX" ] && { echo "Error: must be run inside tmux" >&2; exit 1; }
command -v fzf &>/dev/null || { echo "Error: fzf not found" >&2; exit 1; }

selected=$(fzf \
  --ansi \
  --with-nth=3.. \
  --delimiter=$'\t' \
  --preview='tmux capture-pane -p -e -t {1}:{2} 2>&1 | grep -v "^$" | tail -40' \
  --preview-window='right,55%,border-left,follow' \
  --header='tmux windows  [Enter: switch / Ctrl-R: reload / Esc: cancel]' \
  --prompt='window> ' \
  --bind="start:reload:tmux-claude --list" \
  --bind="ctrl-r:reload:tmux-claude --list" \
  --bind="load:reload-sync(sleep 2; tmux-claude --list)+rebind(load)" < /dev/null)

[ -z "$selected" ] && exit 0

target_session=$(printf '%s' "$selected" | cut -f1)
target_window=$(printf '%s' "$selected" | cut -f2)

tmux switch-client -t "$target_session"
tmux select-window -t "${target_session}:${target_window}"
