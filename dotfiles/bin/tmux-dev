#!/bin/bash

# Select repository with fzf, choosing mode via key binding
output=$(ghq list | fzf +m \
  --expect=ctrl-d,ctrl-b \
  --header='ctrl-d: dev (nvim+claude)  ctrl-b: bash  enter: dev')
[ -z "$output" ] && exit 0

key=$(echo "$output" | head -1)
dir=$(echo "$output" | tail -1)
repo_path="$(ghq root)/$dir"
repo_name=$(basename "$dir")

# Ask for window title
read -rp "Window title [$repo_name]: " title
title="${title:-$repo_name}"

# Create new window and focus it (works when called from popup)
window_id=$(tmux new-window -P -F '#{window_id}' -c "$repo_path" -n "$title")
tmux select-window -t "$window_id"

case "$key" in
  ctrl-b)
    # bash only
    ;;
  *)
    # dev: split and open claude + nvim
    tmux split-window -h -l 30% -c "$repo_path"
    tmux send-keys "claude" Enter
    tmux select-pane -L
    tmux send-keys "nvim" Enter
    ;;
esac
