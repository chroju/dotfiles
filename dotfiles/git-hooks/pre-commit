#!/bin/bash
# Reject commits that introduce hardcoded `/Users/<name>/` paths.
# Use `$HOME` or `~` instead — see CLAUDE.md.

set -u

# Collect added lines from staged diff (skip new-file `+++` markers).
added=$(git diff --cached --diff-filter=ACM -U0 \
  | grep -E '^\+' | grep -vE '^\+\+\+')

# Flag occurrences of `/Users/<name>/`. We extract per-occurrence
# (grep -o) instead of per-line so that a line mixing a ghq path
# (e.g. `github.com/chroju/...`) with a hardcoded one is still caught.
# `/Users/<name>/` only appears at the start of an absolute path, so
# the `github.com/...` segment of a ghq path is not matched here and
# no special exclusion is needed.
violations=$(printf '%s\n' "$added" \
  | grep -oE '/Users/[^/[:space:]"'"'"']+/' \
  | sort -u \
  || true)

if [ -n "$violations" ]; then
  cat >&2 <<EOF
ERROR: staged changes contain hardcoded /Users/<name>/ paths.
Use \$HOME or ~ instead (see CLAUDE.md).

Offending added lines:
$violations

To bypass intentionally: git commit --no-verify
EOF
  exit 1
fi

exit 0
