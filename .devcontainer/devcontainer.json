{
  "name": "dotfiles",
  "image": "ubuntu:24.04",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/aws-cli:1": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
  },
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind,readonly",
    "source=${localEnv:HOME}/.aws,target=/root/.aws,type=bind",
    "source=${localEnv:HOME}/.claude/projects-devcontainer,target=/root/.claude/projects,type=bind",
    "source=${localEnv:HOME}/.claude/todos-devcontainer,target=/root/.claude/todos,type=bind"
  ],
  "initializeCommand": "bash .devcontainer/init.sh",
  "runArgs": ["--env-file", ".devcontainer/.env.devcontainer"],
  "remoteUser": "root"
}
